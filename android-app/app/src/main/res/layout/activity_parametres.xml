<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    >

    <ImageView
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:src="@android:drawable/ic_menu_manage"
        android:layout_marginBottom="16dp"
        app:tint="@color/colorPrimary" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Paramètres"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimary"
        android:layout_marginBottom="40dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choisissez votre thème :"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnThemeClair"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="☀  Thème clair"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#FFF9C4"
        android:textColor="?android:attr/textColorPrimary"
        android:layout_marginBottom="16dp"
        app:cornerRadius="12dp" />

    <Button
        android:id="@+id/btnThemeSombre"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="🌙  Thème sombre"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#37474F"
        android:textColor="@color/white"
        android:layout_marginBottom="40dp"
        app:cornerRadius="12dp" />

    <Button
        android:id="@+id/btnRetour"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Retour à l'accueil"
        android:textSize="16sp"
        android:textStyle="bold"
        android:backgroundTint="#607D8B"
        android:textColor="@color/white"
        app:cornerRadius="12dp" />

</LinearLayout>
