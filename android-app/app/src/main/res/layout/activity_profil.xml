<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollViewProfil"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/rootLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:background="@color/white">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mon Profil"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:layout_marginBottom="24dp" />

        <!-- Informations utilisateur -->
        <TextView
            android:id="@+id/tvEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email : --"
            android:textSize="16sp"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvPremiereConnexion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Première connexion : --"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDerniereConnexion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dernière connexion : --"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="24dp" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <!-- Exercice 4 : Visites du profil -->
        <TextView
            android:id="@+id/tvDerniereVisite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dernière visite du profil : --"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvNbVisites"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre de visites du profil : 0"
            android:textSize="15sp"
            android:textColor="#555555"
            android:layout_marginBottom="24dp" />

        <!-- Séparateur -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#DDDDDD"
            android:layout_marginBottom="16dp" />

        <!-- Exercice 6 : Modification email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modifier mon email"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="12dp" />

        <EditText
            android:id="@+id/etNouvelEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nouvel email"
            android:inputType="textEmailAddress"
            android:padding="12dp"
            android:background="@drawable/input_background"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnChangerEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Changer mon email"
            android:backgroundTint="@color/colorPrimary"
            android:textColor="@color/white"
            android:padding="12dp"
            android:layout_marginBottom="24dp" />

        <!-- Bouton Retour -->
        <Button
            android:id="@+id/btnRetour"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Retour"
            android:backgroundTint="#607D8B"
            android:textColor="@color/white"
            android:padding="12dp" />

    </LinearLayout>
</ScrollView>
